# === API Keys ===
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# === Model Paths ===
DISTILBERT_MODEL_PATH=./models/distilbert-base
L2_FINETUNED_MODEL_PATH=./models/l2_finetuned
DEEPSEEK_MODEL_PATH=./models/deepseek-r1-14b
DEEPSEEK_GGUF_PATH=./models/deepseek-r1-14b-gguf/DeepSeek-R1-Distill-Qwen-14B-Q8_0.gguf

# === Dataset Paths ===
PHISHTANK_CSV_PATH=./datasets/phishtank.csv
TRANCO_CSV_PATH=./datasets/top-1m.csv

# === Service Settings ===
SMTP_HOST=0.0.0.0
SMTP_PORT=1025
API_HOST=0.0.0.0
API_PORT=8000

# === Thresholds ===
L2_SAFE_THRESHOLD=0.9
L2_PHISH_THRESHOLD=0.4

# === Judge Backend: "vllm" or "llama_cpp" ===
JUDGE_BACKEND=llama_cpp

# === Operator Auth ===
# API key required for operator endpoints (decide, retrain, layer toggle).
# Leave empty to disable authentication (not recommended for production).
OPERATOR_API_KEY=
